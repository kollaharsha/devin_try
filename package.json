{
  "name": "aws-ecs-cdk-framework",
  "version": "1.0.0",
  "description": "AWS CDK framework for ECS Fargate services with YAML configuration",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy:dev": "cdk deploy --context environment=dev",
    "deploy:qa": "cdk deploy --context environment=qa",
    "deploy:uat": "cdk deploy --context environment=uat",
    "deploy:prod": "cdk deploy --context environment=prod",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "destroy": "cdk destroy"
  },
  "devDependencies": {
    "@types/jest": "^29.4.0",
    "@types/node": "^18.14.6",
    "jest": "^29.5.0",
    "ts-jest": "^29.0.5",
    "typescript": "~4.9.5",
    "aws-cdk": "2.87.0"
  },
  "dependencies": {
    "aws-cdk-lib": "2.87.0",
    "constructs": "^10.0.0",
    "yaml": "^2.3.1",
    "source-map-support": "^0.5.21"
  },
  "keywords": [
    "aws",
    "cdk",
    "ecs",
    "fargate",
    "infrastructure",
    "yaml",
    "multi-environment"
  ],
  "author": "kollaharsha",
  "license": "MIT"
}
